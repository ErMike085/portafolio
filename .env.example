# Frontend endpoints
VITE_CONTACT_ENDPOINT=/api/contact
# Optional LOCAL fallback when /api/contact is unavailable (must be HTTPS).
# In production keep this empty if CSP is connect-src 'self'.
VITE_CONTACT_FALLBACK_ENDPOINT=https://formsubmit.co/ajax/correo@correo.com

# Serverless API (Vercel)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL="Portafolio <onboarding@resend.dev>"
CONTACT_TO_EMAIL=correo@correo.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://tu-dominio.com,https://www.tu-dominio.com
